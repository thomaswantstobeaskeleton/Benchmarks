[
  {
    "Id": "startup-disable-onedrive",
    "Name": "Disable OneDrive Startup",
    "Category": "Startup manager",
    "Description": "Disables OneDrive auto-start entry for current user.",
    "RiskLevel": "Safe",
    "BeforeValueCommand": "Get-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run' -Name 'OneDrive' -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OneDrive",
    "ApplyCommand": "Remove-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run' -Name 'OneDrive' -ErrorAction SilentlyContinue",
    "RollbackCommand": "Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run' -Name 'OneDrive' -Value 'C:\\Program Files\\Microsoft OneDrive\\OneDrive.exe /background'",
    "AfterExpectedValue": "(null)",
    "RequiresAdmin": false,
    "Presets": ["Safe Optimization", "Low-End PC Optimization"],
    "Source": "Windows native"
  },
  {
    "Id": "disable-fso-cs2",
    "Name": "Disable Fullscreen Optimizations (example app)",
    "Category": "Gaming mode tweaks",
    "Description": "Sets compatibility flag to disable Fullscreen Optimizations for a selected game executable path.",
    "RiskLevel": "Moderate",
    "BeforeValueCommand": "Get-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows NT\\CurrentVersion\\AppCompatFlags\\Layers' -ErrorAction SilentlyContinue",
    "ApplyCommand": "Write-Output 'Use per-game path command template in docs: set ~ DISABLEDXMAXIMIZEDWINDOWEDMODE'",
    "RollbackCommand": "Write-Output 'Remove the corresponding Layers registry value for the game executable'",
    "AfterExpectedValue": "Flag entry added",
    "RequiresAdmin": false,
    "Presets": ["Gaming Optimization"],
    "Source": "Blur Busters forums"
  },
  {
    "Id": "visualfx-performance",
    "Name": "Visual Effects: Best Performance",
    "Category": "Windows visual effects tuning",
    "Description": "Sets visual effects profile for performance.",
    "RiskLevel": "Safe",
    "BeforeValueCommand": "Get-ItemPropertyValue -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\VisualEffects' -Name 'VisualFXSetting'",
    "ApplyCommand": "Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\VisualEffects' -Name 'VisualFXSetting' -Type DWord -Value 2",
    "RollbackCommand": "Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\VisualEffects' -Name 'VisualFXSetting' -Type DWord -Value 0",
    "AfterExpectedValue": "2",
    "RequiresAdmin": false,
    "Presets": ["Safe Optimization", "Low-End PC Optimization"],
    "Source": "Windows native"
  },
  {
    "Id": "temp-clean",
    "Name": "Temporary File Cleanup",
    "Category": "Temporary file cleanup",
    "Description": "Clears user temp folders.",
    "RiskLevel": "Safe",
    "BeforeValueCommand": "(Get-ChildItem $env:TEMP -Recurse -ErrorAction SilentlyContinue | Measure-Object Length -Sum).Sum",
    "ApplyCommand": "Get-ChildItem $env:TEMP -Recurse -ErrorAction SilentlyContinue | Remove-Item -Force -Recurse -ErrorAction SilentlyContinue",
    "RollbackCommand": "Write-Output 'Not reversible: cleanup only'",
    "AfterExpectedValue": "0",
    "RequiresAdmin": false,
    "Presets": ["Safe Optimization", "Low-End PC Optimization", "Privacy-Focused"],
    "Source": "Windows native"
  },
  {
    "Id": "gaming-power-plan",
    "Name": "Set High Performance Plan",
    "Category": "Power plan optimization",
    "Description": "Activates High Performance power plan.",
    "RiskLevel": "Safe",
    "BeforeValueCommand": "powercfg /GetActiveScheme",
    "ApplyCommand": "powercfg /S SCHEME_MIN",
    "RollbackCommand": "powercfg /S SCHEME_BALANCED",
    "AfterExpectedValue": "High performance",
    "RequiresAdmin": true,
    "Presets": ["Gaming Optimization", "Low-End PC Optimization"],
    "Source": "Windows native"
  },
  {
    "Id": "network-autotuning-normal",
    "Name": "TCP Auto-Tuning Normal",
    "Category": "Network optimization",
    "Description": "Sets netsh autotuning back to normal as safe baseline.",
    "RiskLevel": "Safe",
    "BeforeValueCommand": "netsh int tcp show global",
    "ApplyCommand": "netsh int tcp set global autotuninglevel=normal",
    "RollbackCommand": "netsh int tcp set global autotuninglevel=normal",
    "AfterExpectedValue": "autotuninglevel normal",
    "RequiresAdmin": true,
    "Presets": ["Safe Optimization", "Gaming Optimization"],
    "Source": "Windows networking best practices"
  }
]
